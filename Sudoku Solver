#include <iostream>
using namespace std;

const int N = 9;

// Print Sudoku Grid
void printGrid(int grid[N][N]) {
    cout << "\nSolved Sudoku:\n";
    for (int i = 0; i < N; i++) {
        for (int j = 0; j < N; j++) {
            cout << grid[i][j] << " ";
        }
        cout << endl;
    }
}

// Check if number is safe
bool isSafe(int grid[N][N], int row, int col, int num) {

    // Row check
    for (int x = 0; x < N; x++)
        if (grid[row][x] == num)
            return false;

    // Column check
    for (int x = 0; x < N; x++)
        if (grid[x][col] == num)
            return false;

    // 3x3 Box check
    int startRow = row - row % 3;
    int startCol = col - col % 3;

    for (int i = 0; i < 3; i++)
        for (int j = 0; j < 3; j++)
            if (grid[i + startRow][j + startCol] == num)
                return false;

    return true;
}

// Backtracking Solver
bool solveSudoku(int grid[N][N]) {

    int row, col;
    bool empty = false;

    // Find empty cell
    for (row = 0; row < N; row++) {
        for (col = 0; col < N; col++) {
            if (grid[row][col] == 0) {
                empty = true;
                break;
            }
        }
        if (empty) break;
    }

    // If no empty cell, solved
    if (!empty)
        return true;

    // Try numbers 1 to 9
    for (int num = 1; num <= 9; num++) {

        if (isSafe(grid, row, col, num)) {
            grid[row][col] = num;

            if (solveSudoku(grid))
                return true;

            // Backtrack
            grid[row][col] = 0;
        }
    }

    return false;
}

// Main Function
int main() {

    int grid[N][N];

    cout << "Enter Sudoku (use 0 for empty cells):\n";

    // Input
    for (int i = 0; i < N; i++)
        for (int j = 0; j < N; j++)
            cin >> grid[i][j];

    // Solve
    if (solveSudoku(grid))
        printGrid(grid);
    else
        cout << "No solution exists!\n";

    return 0;
}
